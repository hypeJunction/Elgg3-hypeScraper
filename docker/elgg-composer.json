{
    "name": "elgg/test-site",
    "type": "project",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "elgg/elgg": "5.1.4",
        "composer/installers": "^2.0",
        "phpunit/phpunit": "~9.5"
    },
    "replace": {
        "roave/security-advisories": "dev-master"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "config": {
        "allow-plugins": {
            "composer/installers": true
        },
        "audit": {
            "block-insecure": false
        }
    }
}
